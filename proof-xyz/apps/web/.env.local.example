# Base URL of the FastAPI backend. Used by both server and client components.
NEXT_PUBLIC_API_BASE_URL=

# Optional: the public domain used to build the shareable resume link.
# Defaults to the browser's current origin (e.g. http://localhost:3000) if unset.
# In production set this to your real domain, e.g. https://proofdeck.dev
NEXT_PUBLIC_PUBLIC_BASE_URL=
