# --- Generative layer ---
# Which provider synthesizes the cards: auto | gemini | claude | rules.
# "auto" uses Gemini if its key is set, then Claude, else the rules fallback.
LLM_PROVIDER=auto

# Google Gemini — FREE tier, no credit card needed.
# Get a key at https://aistudio.google.com/apikey  (recommended)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude — optional paid alternate.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- GitHub ---
# Optional personal access token: raises the public rate limit (60 -> 5000/hr)
# and enables ingesting private repos. Generate at github.com/settings/tokens.
GITHUB_TOKEN=

# --- GitHub OAuth app (optional — username ingestion works without it) ---
# Create at github.com/settings/developers. Callback URL must be:
#   http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- URLs ---
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# --- Storage ---
# SQLite for local dev; swap for a Postgres DSN in production.
DATABASE_URL=sqlite:///./proof.db

# Number of repos to ingest per profile (ranked by stars then recency).
MAX_REPOS=50
